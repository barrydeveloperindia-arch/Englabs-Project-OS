rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {

    // ----------------------------------------------------------------------
    // FUNCTION DEFINITIONS (Role-Based Access Control)
    // ----------------------------------------------------------------------
    function isAuthenticated() {
      return request.auth != null;
    }

    // Dynamic Role Fetcher (Assuming a user_roles collection exists, or overriding for staging testing)
    function getUserRole() {
      // For staging testing, if email is admin, treat as admin, else treat as staff
      return (request.auth.token.email == 'admin@englabs.com' || request.auth.token.email == 'englabscivilteam@gmail.com' || request.auth.token.email == 'gauravpanchalenglab@gmail.com') ? 'ADMIN' : 'STAFF';
    }

    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'ADMIN';
    }

    function isStaff() {
      return isAuthenticated() && (getUserRole() == 'STAFF' || getUserRole() == 'ADMIN');
    }

    // ----------------------------------------------------------------------
    // COLLECTION RULES
    // ----------------------------------------------------------------------

    // 1. Projects Master 
    match /projects_master/{projectId} {
      allow read: if isAuthenticated();
      // Admins can create/delete. Staff can only update cost metrics.
      allow create, delete: if isAdmin();
      allow update: if isStaff();
    }

    // Projects (Vite App Sync)
    match /projects/{projectId} {
      allow read: if isAuthenticated();
      allow create, update, delete: if isStaff();
    }

    // 2. Inventory Ledger (Append Only)
    match /inventory_ledger/{txnId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; // Immutable ledger enforcement
    }

    // 3. Vendor Master & Ledger
    match /vendors_master/{vendorId} {
      allow read: if isAuthenticated();
      allow write: if isStaff();
    }
    match /vendor_ledger/{txnId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; // Immutable ledger enforcement
    }

    // 4. Accounts & Finance Ledger
    match /finance_ledger/{txnId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; // Immutable
    }

    // 5. Porter Services Ledger
    match /porter_ledger/{txnId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; // Immutable
    }

    // 6. Food & Hospitality Ledger
    match /food_ledger/{txnId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; // Immutable
    }

    // 7. HR & Staff Management
    match /staff_master/{staffId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin(); // Only Admins can register/edit staff
    }
    match /staff_master/{docId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    match /attendance_ledger/{docId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; 
    }
    match /salary_ledger/{docId} {
      allow read, write: if isAdmin(); // Strictly private
    }
    match /advance_ledger/{docId} {
      allow read, write: if isAdmin(); // Strictly private
    }
    match /overtime_ledger/{docId} {
      allow read, write: if isAdmin(); // Strictly private
    }
    match /leave_ledger/{docId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update: if isAdmin(); // Only admins can approve/reject
      allow delete: if false;
    }
    match /employee_documents/{docId} {
      allow read: if isAuthenticated();
      allow create: if isStaff();
      allow update, delete: if false; // Immutable audit log of documents
    }

    // SPRINT 3: Settings & Audit Logs
    match /system_settings/{docId} {
      allow read, write: if isAdmin(); // STRICTLY ADMIN ONLY
    }
    
    match /audit_logs/{logId} {
      // ANY authenticated user can trigger a creation log entry.
      // ONLY admins can read the log.
      // NO ONE can ever modify or delete a log (Immutable Protocol).
      allow create: if isAuthenticated();
      allow read: if isAdmin();
      allow update, delete: if false;
    }
  }
}
