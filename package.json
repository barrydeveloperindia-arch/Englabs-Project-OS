{
  "name": "englabs-projects-antigravity",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:run": "vitest run",
    "test:e2e": "playwright test",
    "test:mobile:emulated": "playwright test src/tests/e2e/mobile.test.ts",
    "test:mobile:real": "playwright test src/tests/e2e/mobile.test.ts --project=\"Mobile Chrome (Pixel 5)\"",
    "test:mobile:diagnose": "node src/tests/native/scripts/parse_mobile_feedback.js",
    "qa:protect": "node src/tests/qa_agent/protection_agent.cjs",
    "agent:daemon": "node src/tests/qa_agent/master_handover_agent.cjs"
  },
  "dependencies": {
    "@capacitor/android": "^8.3.4",
    "@capacitor/cli": "^8.3.4",
    "@capacitor/core": "^8.3.4",
    "@google/generative-ai": "^0.24.1",
    "@tailwindcss/vite": "^4.2.4",
    "dotenv": "^17.4.2",
    "firebase": "^12.12.1",
    "html2canvas": "^1.4.1",
    "jspdf": "^4.2.1",
    "lucide-react": "^0.300.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "xlsx": "^0.18.5"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.2.4",
    "@testing-library/jest-dom": "^6.1.5",
    "@testing-library/react": "^14.1.2",
    "@types/react": "^18.2.43",
    "@types/react-dom": "^18.2.17",
    "@vitejs/plugin-react": "^4.2.1",
    "@vitest/ui": "^1.0.4",
    "autoprefixer": "^10.5.0",
    "jsdom": "^23.0.1",
    "postcss": "^8.5.13",
    "tailwindcss": "^4.2.4",
    "typescript": "^5.2.2",
    "vite": "^5.0.8",
    "vitest": "^1.0.4"
  }
}
